# ─────────────────────────────────────────────────────────────────────────────
#  world.env  —  automagicraft world configuration
#
#  Edit any value here, then restart `pnpm dev` (or rebuild) to apply.
#  All values are optional — removing a line restores the built-in default.
# ─────────────────────────────────────────────────────────────────────────────

# ── World ─────────────────────────────────────────────────────────────────────

# Seed used for procedural terrain generation.
# Any integer. Different values produce completely different worlds.
# Default: 1337
WORLD_SEED=1337

# ── Time ──────────────────────────────────────────────────────────────────────

# Length of a full day/night cycle, in seconds of real time.
# 60  → fast cycling for testing / screenshots
# 150 → default, a leisurely day
# 600 → slow, almost imperceptible drift
# Default: 150
DAY_LENGTH=150

# ── Mobs ──────────────────────────────────────────────────────────────────────

# Total number of birds scattered across the world at startup.
# They are seeded, so the same WORLD_SEED always places them identically.
# Default: 80
BIRD_AMOUNT=500
DEER_AMOUNT=100

# ── Player ────────────────────────────────────────────────────────────────────

# Top walking speed in blocks per second.
# Water-wading speed scales with this automatically (≈ 38 %).
# Default: 4.6
WALK_SPEED=4.6

# ── Environment ───────────────────────────────────────────────────────────────

# Base fog density. Higher = thicker fog, shorter view distance.
# 0.003 → crisp, long views
# 0.007 → default, horizon dissolves naturally
# 0.015 → misty / atmospheric
# Default: 0.007
FOG_DENSITY=0.007
